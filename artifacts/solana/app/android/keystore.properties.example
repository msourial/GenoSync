# Release signing credentials template.
#
# Copy to `keystore.properties` (same dir) and fill in real values to produce
# a signed Seeker release APK via `./gradlew :app:assembleRelease`.
#
# `keystore.properties` and the .keystore file are gitignored — NEVER commit
# real signing secrets. If keystore.properties is absent, the release build
# falls back to the debug key (fine for CI / local testing, NOT for Seeker).
#
# Generate the keystore:
#   keytool -genkeypair -v -keystore app/genosync-release.keystore \
#     -alias genosync -keyalg RSA -keysize 2048 -validity 10000

RELEASE_STORE_FILE=genosync-release.keystore
RELEASE_STORE_PASSWORD=changeme
RELEASE_KEY_ALIAS=genosync
RELEASE_KEY_PASSWORD=changeme
