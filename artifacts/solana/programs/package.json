{
  "name": "@genosync/programs",
  "version": "0.0.0",
  "private": true,
  "description": "GenoSync Solana Anchor programs (staking, cNFT, governance)",
  "scripts": {
    "build:staking": "anchor build --manifest-path staking/Cargo.toml",
    "build:cnft": "anchor build --manifest-path cnft/Cargo.toml",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet-beta"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "~5.9.2"
  }
}
