# Wallet that will deploy AuraToken on Base / Base Sepolia.
# Fund it with a small amount of Base ETH (Sepolia faucet for testnet).
DEPLOYER_PRIVATE_KEY=0x...

# Optional — only needed if you want to verify on BaseScan
BASESCAN_API_KEY=

# Optional RPC overrides (defaults to public Base endpoints)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
